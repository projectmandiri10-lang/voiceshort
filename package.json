{
  "name": "voice-shorts-general-app",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/server",
    "apps/web"
  ],
  "scripts": {
    "dev": "concurrently \"npm:dev -w apps/server\" \"npm:dev -w apps/web\"",
    "build": "npm run build -w apps/server && npm run build -w apps/web",
    "test": "npm run test -w apps/server && npm run test -w apps/web",
    "start": "npm run start -w apps/server"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "concurrently": "^9.2.1",
    "esbuild": "^0.27.3"
  },
  "dependencies": {
    "ajv": "^8.18.0"
  }
}
